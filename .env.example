# Pagila Database Deployment - Environment Configuration Template
#
# Instructions:
#   1. Copy this file to .env
#   2. Fill in the actual values for your deployment
#   3. Never commit .env with real credentials
#   4. Ensure .env is in .gitignore
#
# Security Warning:
#   This file contains sensitive connection details. Always protect .env files
#   and never share them publicly or commit them to version control.

# ============================================================================
# Aurora PostgreSQL Connection
# ============================================================================

# Database host (Aurora cluster endpoint)
# Format: <cluster-name>.xxxxx.<region>.rds.amazonaws.com
DB_HOST=pagila-cluster.xxxxx.us-east-1.rds.amazonaws.com

# Database port (default: 5432)
DB_PORT=5432

# Database name (default: pagila)
DB_NAME=pagila

# Database user (default: postgres)
# Note: Must have privileges to create tables and load data
DB_USER=postgres

# Database password
# Requirements: 8+ characters, mixed case, numbers, special characters
# Never use simple/test passwords in production
DB_PASSWORD=YourSecurePassword123!

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS region where resources are deployed
AWS_REGION=us-east-1

# AWS account ID (optional, for cross-account deployments)
# AWS_ACCOUNT_ID=123456789012

# ============================================================================
# CDK Deployment Configuration
# ============================================================================

# Enable CDK deployment (true/false)
# Set to false to skip infrastructure deployment
CDK_DEPLOY=true

# CDK stack name for the serverless application
CDK_CONTEXT_STACK_NAME=pagila-serverless-stack

# Environment tag for deployments (dev/staging/prod)
# CDK_ENVIRONMENT=dev

# ============================================================================
# API Gateway Configuration
# ============================================================================

# API Gateway endpoint URL
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/<stage>
API_ENDPOINT=https://xxxxxx.execute-api.us-east-1.amazonaws.com/prod

# API stage name (prod, dev, staging, etc.)
# API_STAGE=prod

# ============================================================================
# Optional: Lambda & Application Configuration
# ============================================================================

# Lambda function timeout in seconds
# LAMBDA_TIMEOUT=30

# Lambda memory allocation in MB (128-10240)
# LAMBDA_MEMORY=256

# Application log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================================================
# Optional: Monitoring & Observability
# ============================================================================

# CloudWatch log group name prefix
# CLOUDWATCH_LOG_GROUP=/aws/lambda/pagila

# Enable detailed CloudWatch metrics
# ENABLE_DETAILED_METRICS=false

# SNS topic ARN for alerts (optional)
# ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:pagila-alerts
