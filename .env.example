# Pagila (web-only) - local config for talking to the deployed API.
#
#   cp .env.example .env   and fill in API_ENDPOINT after `cdk deploy`.
#
# The database is private: there are NO DB credentials here. The Lambda reads
# them from Secrets Manager inside the VPC; you never connect to Postgres
# directly. Everything goes through the API.

# API Gateway base URL - the "APIEndpoint" output printed by `cdk deploy`.
# e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod/
API_ENDPOINT=

# Region your stack is deployed in (used by the AWS CLI / helper scripts).
AWS_REGION=us-east-1
